{
    "vhosts": [
        {
            "name": "my_vhost"
        }
    ],
    "permissions": [
        {
            "user": "guest",
            "vhost": "my_vhost",
            "configure": ".*",
            "write": ".*",
            "read": ".*"
        }
    ],
    "parameters": [
        {
            "component": "shovel",
            "name": "local_shovel",
            "vhost": "/",
            "value": {
                "src-uri": "amqp://guest:guest@rabbit1:5672",
                "src-queue": "source_q",
                "dest-uri": "amqp://guest:guest@rabbit1:5672",
                "dest-queue": "dest_q",
                "ack-mode": "on-confirm"
            }
        }
    ]
}